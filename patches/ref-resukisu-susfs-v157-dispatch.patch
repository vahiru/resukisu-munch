 #ifdef CONFIG_KSU_SUSFS
+struct susfs_ref_enabled_features {
+    char enabled_features[8192];
+    int err;
+};
+
+struct susfs_ref_string_info {
+    char value[16];
+    int err;
+};
+
+static void susfs_ref_append_feature(char *buf, size_t *copied, const char *feature)
+{
+    size_t len = strlen(feature);
+
+    if (*copied + len >= sizeof(((struct susfs_ref_enabled_features *)0)->enabled_features))
+        return;
+
+    memcpy(buf + *copied, feature, len);
+    *copied += len;
+}
+
+static void susfs_ref_show_enabled_features(void __user **user_info)
+{
+    struct susfs_ref_enabled_features *info;
+    size_t copied = 0;
+
+    info = kzalloc(sizeof(*info), GFP_KERNEL);
+    if (!info)
+        return;
+
+#ifdef CONFIG_KSU_SUSFS_SUS_PATH
+    susfs_ref_append_feature(info->enabled_features, &copied, "CONFIG_KSU_SUSFS_SUS_PATH\n");
+#endif
+#ifdef CONFIG_KSU_SUSFS_SUS_MOUNT
+    susfs_ref_append_feature(info->enabled_features, &copied, "CONFIG_KSU_SUSFS_SUS_MOUNT\n");
+#endif
+#ifdef CONFIG_KSU_SUSFS_SUS_KSTAT
+    susfs_ref_append_feature(info->enabled_features, &copied, "CONFIG_KSU_SUSFS_SUS_KSTAT\n");
+#endif
+#ifdef CONFIG_KSU_SUSFS_SPOOF_UNAME
+    susfs_ref_append_feature(info->enabled_features, &copied, "CONFIG_KSU_SUSFS_SPOOF_UNAME\n");
+#endif
+#ifdef CONFIG_KSU_SUSFS_ENABLE_LOG
+    susfs_ref_append_feature(info->enabled_features, &copied, "CONFIG_KSU_SUSFS_ENABLE_LOG\n");
+#endif
+#ifdef CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS
+    susfs_ref_append_feature(info->enabled_features, &copied, "CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS\n");
+#endif
+#ifdef CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG
+    susfs_ref_append_feature(info->enabled_features, &copied, "CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG\n");
+#endif
+#ifdef CONFIG_KSU_SUSFS_OPEN_REDIRECT
+    susfs_ref_append_feature(info->enabled_features, &copied, "CONFIG_KSU_SUSFS_OPEN_REDIRECT\n");
+#endif
+
+    if (copy_to_user((void __user *)*user_info, info, sizeof(*info)))
+        info->err = -EFAULT;
+    kfree(info);
+}
+
+static void susfs_ref_show_string(void __user **user_info, const char *value)
+{
+    struct susfs_ref_string_info info = {0};
+
+    strncpy(info.value, value, sizeof(info.value) - 1);
+    if (copy_to_user((void __user *)*user_info, &info, sizeof(info)))
+        info.err = -EFAULT;
+}
